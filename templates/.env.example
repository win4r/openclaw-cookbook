# ==============================================================================
# OpenClaw Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ==============================================================================

# --- LLM Provider API Keys ---------------------------------------------------

# Anthropic (Claude) — required if using Anthropic models
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# OpenAI — required if using OpenAI models
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Google (Gemini) — optional
# GOOGLE_API_KEY=

# DeepSeek — optional
# DEEPSEEK_API_KEY=

# --- Gateway ------------------------------------------------------------------

# Gateway auth token. Used when auth.mode is "token".
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPENCLAW_GATEWAY_TOKEN=

# Port override (default: 18789)
# OPENCLAW_PORT=18789

# --- Channel Plugins ---------------------------------------------------------

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Discord bot token
# DISCORD_BOT_TOKEN=

# Slack bot token
# SLACK_BOT_TOKEN=

# --- Memory (LanceDB) --------------------------------------------------------

# Jina AI API key for embeddings
# Required if memory-lancedb-pro plugin is enabled
JINA_API_KEY=

# --- Exec Tool ----------------------------------------------------------------

# Override the shell used by the exec tool (default: system shell)
# OPENCLAW_SHELL=/bin/bash

# --- Logging ------------------------------------------------------------------

# Log level: debug, info, warn, error (default: info)
# OPENCLAW_LOG_LEVEL=info

# Log file path (default: stdout only)
# OPENCLAW_LOG_FILE=./logs/openclaw.log

# --- Advanced -----------------------------------------------------------------

# Node.js memory limit (useful for large LanceDB indexes)
# NODE_OPTIONS=--max-old-space-size=4096

# HTTP proxy for outbound API calls
# HTTPS_PROXY=
# HTTP_PROXY=
# NO_PROXY=localhost,127.0.0.1

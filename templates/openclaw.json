// OpenClaw Configuration Template
// Copy this file to your project root as openclaw.json and customize.
// JSON does not natively support comments; strip them before use or
// use OpenClaw's built-in comment-stripping loader.
{
  // ---------------------------------------------------------------------------
  // Gateway — core server settings
  // ---------------------------------------------------------------------------
  "gateway": {
    // Port the HTTP gateway listens on.
    "port": 18789,

    // Operating mode:
    //   "local"  — local usage, simplified auth
    "mode": "local",

    // Bind address:
    //   "loopback" — only accept connections from localhost
    "bind": "loopback",

    // Authentication for API access.
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },

  // ---------------------------------------------------------------------------
  // Models — LLM provider configuration
  // ---------------------------------------------------------------------------
  "models": {
    "providers": {
      // Anthropic (Claude)
      "anthropic": {
        // Set ANTHROPIC_API_KEY via env var.
        "models": [
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6" },
          { "id": "claude-opus-4-6", "name": "Claude Opus 4.6" }
        ]
      },

      // OpenAI
      "openai": {
        // Set OPENAI_API_KEY via env var.
        "models": [
          { "id": "gpt-5.4", "name": "GPT 5.4" },
          { "id": "gpt-4o", "name": "GPT 4o" }
        ]
      }

      // MiniMax (Anthropic-compatible)
      // "minimax": {
      //   "baseUrl": "https://api.minimaxi.com/anthropic",
      //   "api": "anthropic-messages",
      //   "authHeader": true,
      //   "models": [
      //     { "id": "MiniMax-M2.7", "name": "MiniMax M2.7" }
      //   ]
      // }
    }
  },

  // ---------------------------------------------------------------------------
  // Agents — define one or more agents with distinct personas and models
  // ---------------------------------------------------------------------------
  "agents": {
    // Default model settings applied to all agents unless overridden.
    "defaults": {
      "model": {
        // Primary model used for responses (provider/model format).
        "primary": "anthropic/claude-sonnet-4-6",

        // Fallback models if the primary is unavailable or rate-limited.
        "fallbacks": ["openai/gpt-5.4"]
      }
    },

    // Agent list. Each agent has its own workspace directory and config.
    "list": [
      {
        // Unique identifier. Referenced by channel routing via bindings.
        "id": "main",

        // Human-readable name.
        "name": "Assistant",

        // Identity metadata.
        "identity": {
          "name": "Assistant"
        },

        // Override default model for this agent (optional).
        "model": {
          "primary": "anthropic/claude-sonnet-4-6",
          "fallbacks": ["openai/gpt-5.4"]
        },

        // Path to this agent's workspace directory (relative to project root).
        // Contains SOUL.md, AGENTS.md, TOOLS.md, etc.
        "workspace": "./workspace"
      }

      // Add more agents for specialization:
      // {
      //   "id": "coding",
      //   "name": "Coding Assistant",
      //   "identity": { "name": "Coding Assistant" },
      //   "model": { "primary": "anthropic/claude-opus-4-6", "fallbacks": ["openai/gpt-5.4"] },
      //   "workspace": "./workspace-coding"
      // },
      // {
      //   "id": "support",
      //   "name": "Customer Support",
      //   "identity": { "name": "Customer Support" },
      //   "model": { "primary": "anthropic/claude-sonnet-4-6", "fallbacks": ["openai/gpt-4o"] },
      //   "workspace": "./workspace-support"
      // }
    ]
  },

  // ---------------------------------------------------------------------------
  // Channels — messaging platform integrations
  // ---------------------------------------------------------------------------
  "channels": {
    // Telegram channel integration.
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist",
      "streaming": "partial",
      "accounts": {
        "main-bot": {
          // Bot token from @BotFather. Set via TELEGRAM_BOT_TOKEN env var.
          "botToken": "${TELEGRAM_BOT_TOKEN}",
          "dmPolicy": "pairing",
          "groupPolicy": "allowlist"
        }
      }
    }

    // Other channels:
    // "discord": { "enabled": false, "accounts": { ... } }
    // "slack":   { "enabled": false, "accounts": { ... } }
  },

  // ---------------------------------------------------------------------------
  // Bindings — route channels to agents
  // ---------------------------------------------------------------------------
  "bindings": [
    { "agentId": "main", "match": { "channel": "telegram", "accountId": "main-bot" } }
  ],

  // ---------------------------------------------------------------------------
  // Plugins — enable and configure extensions
  // ---------------------------------------------------------------------------
  "plugins": {
    // Allowlist of enabled plugins.
    "allow": ["telegram", "memory-lancedb-pro"],

    // Plugin-specific configuration.
    "entries": {
      // Long-term memory via LanceDB vector store.
      "memory-lancedb-pro": {
        "enabled": false,
        "config": {
          "embedding": {
            "provider": "openai-compatible",
            // Jina embeddings API key. Set via JINA_API_KEY env var.
            "apiKey": "${JINA_API_KEY}",
            "model": "jina-embeddings-v5-text-small",
            "baseURL": "https://api.jina.ai/v1",
            "dimensions": 1024
          },
          // Directory for the LanceDB database files.
          "dbPath": "~/.openclaw/memory/lancedb-pro",
          "autoCapture": true,
          "autoRecall": true
        }
      }
    }
  }
}

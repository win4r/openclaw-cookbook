# OpenClaw Environment Configuration
# Copy this file to ~/.openclaw/.env and fill in your values.
#
# At minimum, you need ONE model provider API key.

# ──────────────────────────────────────────────
# Model Provider API Keys
# ──────────────────────────────────────────────

# Anthropic (Claude models)
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT models)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ──────────────────────────────────────────────
# Gateway Security
# ──────────────────────────────────────────────

# Token required to authenticate incoming requests to the gateway.
# Generate one with: openssl rand -hex 32
# Leave empty for local-only development (not recommended for production).
OPENCLAW_GATEWAY_TOKEN=your-gateway-token
